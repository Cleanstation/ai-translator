# Copy this file to:
#   ~/.config/ai-translator/local.env
# Then replace the example values with machine-local settings.

export AI_TRANSLATOR_PROVIDER=http
export AI_TRANSLATOR_PROTOCOL=openai
export AI_TRANSLATOR_BASE_URL="http://localhost:13305/v1"
export AI_TRANSLATOR_MODEL="user.gemma-4-26B-A4B-it-GGUF"
export AI_TRANSLATOR_API_KEY="YOUR_API_KEY"

# Optional: if you keep the key in a file, prefer loading it externally in a
# machine-local file that is NOT committed to git.
# Example:
# export AI_TRANSLATOR_API_KEY="$(<\"$HOME/path/to/lemonade_api_key\")"
